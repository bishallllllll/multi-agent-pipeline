{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/big-pickle",
  "provider": {
    "openai": {
      "baseURL": "https://models.inference.ai.azure.com",
      "models": {
        "default": "gpt-4o"
      },
      "options": {
        "apiKey": "{env:GITHUB_TOKEN}"
      }
    }
  },
  "instructions": ["./AGENTS.md"],
  "agent": {
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  }
}
